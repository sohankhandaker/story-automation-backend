APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars

# Database — SQLite for local dev, PostgreSQL for production
# Local:
DATABASE_URL=sqlite:///./app.db
# Render PostgreSQL (replace with your actual URL):
# DATABASE_URL=postgresql://user:password@host/dbname

# GitHub — Personal Access Token with repo + project scopes
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repo-name
GITHUB_PROJECT_NUMBER=1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Polling
POLL_INTERVAL_SECONDS=60
MAX_REVIEW_CYCLES=5
REVIEWER_REMINDER_HOURS=48
